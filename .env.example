# ============================================================
# DocuMind – Environment Variables
# USAGE: Copy this file to .env and fill in all values.
#        NEVER commit .env to version control.
# ============================================================

# ── Database ─────────────────────────────────────────────────
# Strong password for the PostgreSQL documind_user account.
DB_PASSWORD=change_me_strong_password

# ── JWT Authentication ────────────────────────────────────────
# Minimum 32-character random secret used to sign/verify JWTs.
# Generate one with: openssl rand -hex 32
JWT_SECRET=change_me_at_least_32_char_random_secret_here

# ── Google Gemini API ─────────────────────────────────────────
# Obtain from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
